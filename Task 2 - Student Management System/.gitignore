# ============================================================
# Student Management System — .gitignore
# Covers: Maven, Node/React, IDE files, OS files, and secrets
# ============================================================

# -----------------------------------------------
# Maven / Java Build Artifacts
# -----------------------------------------------
target/
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*

# -----------------------------------------------
# Node / React / Frontend Build Artifacts
# -----------------------------------------------
node_modules/
dist/
build/
.next/
out/
.nuxt/
.cache/
.parcel-cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm
.yarn-integrity

# -----------------------------------------------
# IDE — IntelliJ IDEA
# -----------------------------------------------
.idea/
*.iws
*.iml
*.ipr
out/

# -----------------------------------------------
# IDE — Visual Studio Code
# -----------------------------------------------
.vscode/
*.code-workspace

# -----------------------------------------------
# IDE — Eclipse
# -----------------------------------------------
.classpath
.project
.settings/
bin/
.factorypath

# -----------------------------------------------
# IDE — NetBeans
# -----------------------------------------------
nbproject/
nbbuild/
nbdist/
.nb-gradle/

# -----------------------------------------------
# IDE — STS / Spring Tool Suite
# -----------------------------------------------
.springBeans
.sts4-cache/

# -----------------------------------------------
# Secrets and Environment Files
# -----------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
*.pem
*.key
*.p12
*.jks
application-local.properties
application-local.yml
application-secret.properties
application-secret.yml
secrets/

# -----------------------------------------------
# Database Files
# -----------------------------------------------
*.db
*.sqlite
*.sqlite3
*.h2.db

# -----------------------------------------------
# Logs
# -----------------------------------------------
logs/
*.log
spring.log

# -----------------------------------------------
# OS-Generated Files
# -----------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# -----------------------------------------------
# Test Reports
# -----------------------------------------------
surefire-reports/
failsafe-reports/
test-results/
coverage/
*.lcov

# -----------------------------------------------
# Miscellaneous
# -----------------------------------------------
*.swp
*.swo
*.bak
*.tmp
*.orig
