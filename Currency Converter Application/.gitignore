# =============================================
# Spring Boot / Maven – .gitignore
# =============================================

# ---- Compiled output ----
target/
*.class
*.jar
*.war
*.ear

# ---- Maven wrapper cache ----
.mvn/wrapper/maven-wrapper.jar

# ---- IntelliJ IDEA ----
.idea/
*.iws
*.iml
*.ipr
out/

# ---- Eclipse ----
.classpath
.project
.settings/
bin/

# ---- VS Code ----
.vscode/

# ---- Spring Boot DevTools restart file ----
.spring-boot-devtools.properties

# ---- Logs ----
*.log
logs/

# ---- OS artefacts ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Sensitive config (never commit real secrets) ----
application-prod.properties
application-local.properties
*.env

# ---- AI tooling (internal agent config — not for version control) ----
AGENTS.md
